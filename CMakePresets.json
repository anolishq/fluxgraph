      }
    },
    {
      "name": "ci-linux-release-diagram",
      "configurePreset": "ci-linux-release-diagram",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-linux-release-server",
      "configurePreset": "ci-linux-release-server",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-tsan",
      "configurePreset": "ci-tsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-windows-server",
      "configurePreset": "dev-windows-server",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-windows-release-server",
      "configurePreset": "ci-windows-release-server",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
