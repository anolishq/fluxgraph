{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "FLUXGRAPH_BUILD_TESTS": "ON",
        "FLUXGRAPH_BUILD_EXAMPLES": "OFF",
        "FLUXGRAPH_BUILD_SERVER": "OFF",
        "FLUXGRAPH_BUILD_DIAGRAM_TOOL": "OFF",
        "FLUXGRAPH_JSON_ENABLED": "OFF",
        "FLUXGRAPH_YAML_ENABLED": "OFF"
      }
    },
    {
      "name": "base-windows-msvc",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "toolset": "v145",
      "architecture": "x64",
      "cacheVariables": {
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-windows-v145",
        "VCPKG_HOST_TRIPLET": "x64-windows-v145"
      }
    },
    {
      "name": "dev-debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "FLUXGRAPH_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "dev-release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "FLUXGRAPH_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "dev-windows-debug",
      "inherits": "base-windows-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "FLUXGRAPH_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "dev-windows-release",
      "inherits": "base-windows-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "FLUXGRAPH_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "ci-linux-release",
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "ci-windows-release",
      "inherits": "base-windows-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ci-windows-release-diagram",
      "inherits": "ci-windows-release",
      "cacheVariables": {
        "FLUXGRAPH_BUILD_DIAGRAM_TOOL": "ON",
        "FLUXGRAPH_JSON_ENABLED": "ON"
      }
    },
    {
      "name": "ci-linux-release-json",
      "inherits": "ci-linux-release",
      "cacheVariables": {
        "FLUXGRAPH_JSON_ENABLED": "ON"
      }
    },
    {
      "name": "ci-linux-release-yaml",
      "inherits": "ci-linux-release",
      "cacheVariables": {
        "FLUXGRAPH_YAML_ENABLED": "ON"
      }
    },
    {
      "name": "ci-linux-release-diagram",
      "inherits": "ci-linux-release-json",
      "cacheVariables": {
        "FLUXGRAPH_BUILD_DIAGRAM_TOOL": "ON"
      }
    },
    {
      "name": "ci-linux-release-server",
      "inherits": "ci-linux-release",
      "binaryDir": "${sourceDir}/build-server",
      "cacheVariables": {
        "FLUXGRAPH_BUILD_SERVER": "ON",
        "FLUXGRAPH_JSON_ENABLED": "ON",
        "FLUXGRAPH_YAML_ENABLED": "ON"
      }
    },
    {
      "name": "ci-tsan",
      "inherits": "ci-linux-release-server",
      "binaryDir": "${sourceDir}/build/ci-tsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "VCPKG_TARGET_TRIPLET": "x64-linux-tsan",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "ENABLE_TSAN": "ON"
      }
    },
    {
      "name": "ci-fuzz",
      "inherits": "ci-linux-release",
      "binaryDir": "${sourceDir}/build/ci-fuzz",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "FLUXGRAPH_JSON_ENABLED": "ON",
        "FLUXGRAPH_YAML_ENABLED": "ON",
        "FLUXGRAPH_BUILD_TESTS": "OFF",
        "FLUXGRAPH_BUILD_EXAMPLES": "OFF",
        "ENABLE_FUZZING": "ON"
      }
    },
    {
      "name": "dev-windows-server",
      "inherits": "base-windows-msvc",
      "binaryDir": "${sourceDir}/build-windows-server",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "FLUXGRAPH_BUILD_SERVER": "ON",
        "FLUXGRAPH_JSON_ENABLED": "ON",
        "FLUXGRAPH_YAML_ENABLED": "ON"
      }
    },
    {
      "name": "ci-windows-release-server",
      "inherits": "ci-windows-release",
      "binaryDir": "${sourceDir}/build-windows-server-release",
      "cacheVariables": {
        "FLUXGRAPH_BUILD_SERVER": "ON",
        "FLUXGRAPH_JSON_ENABLED": "ON",
        "FLUXGRAPH_YAML_ENABLED": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug"
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release"
    },
    {
      "name": "dev-windows-debug",
      "configurePreset": "dev-windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "dev-windows-release",
      "configurePreset": "dev-windows-release",
      "configuration": "Release"
    },
    {
      "name": "ci-linux-release",
      "configurePreset": "ci-linux-release"
    },
    {
      "name": "ci-windows-release",
      "configurePreset": "ci-windows-release",
      "configuration": "Release"
    },
    {
      "name": "ci-windows-release-diagram",
      "configurePreset": "ci-windows-release-diagram",
      "configuration": "Release"
    },
    {
      "name": "ci-linux-release-json",
      "configurePreset": "ci-linux-release-json"
    },
    {
      "name": "ci-linux-release-yaml",
      "configurePreset": "ci-linux-release-yaml"
    },
    {
      "name": "ci-linux-release-diagram",
      "configurePreset": "ci-linux-release-diagram"
    },
    {
      "name": "ci-linux-release-server",
      "configurePreset": "ci-linux-release-server"
    },
    {
      "name": "ci-tsan",
      "configurePreset": "ci-tsan"
    },
    {
      "name": "ci-fuzz",
      "configurePreset": "ci-fuzz"
    },
    {
      "name": "dev-windows-server",
      "configurePreset": "dev-windows-server",
      "configuration": "Debug"
    },
    {
      "name": "ci-windows-release-server",
      "configurePreset": "ci-windows-release-server",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-windows-debug",
      "configurePreset": "dev-windows-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-windows-release",
      "configurePreset": "dev-windows-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-linux-release",
      "configurePreset": "ci-linux-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-windows-release",
      "configurePreset": "ci-windows-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-windows-release-diagram",
      "configurePreset": "ci-windows-release-diagram",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-linux-release-json",
      "configurePreset": "ci-linux-release-json",
      "output": {
